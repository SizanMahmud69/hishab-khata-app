
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =================================================================
    // Helper Functions
    // =================================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Check if the user is an admin by looking at the 'isAdmin' flag in their user document.
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // =================================================================
    // User-specific Data (/users/{userId}/...)
    // =================================================================
    match /users/{userId} {
      // Users can read and update their own profiles. Admins can read any user's profile.
      allow get: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin(); // Admin can update for refunds, etc.
      
      // Allow creating a user profile during registration.
      // Allow listing only for referral code checks during registration.
      allow create: if isSignedIn();
      allow list: if request.query.limit <= 1;

      // Sub-collections are only accessible by their owner.
      match /transactions/{transactionId} { allow read, write: if isOwner(userId); }
      match /debtNotes/{debtNoteId} { allow read, write: if isOwner(userId); }
      match /checkIns/{checkInId} { allow read, write: if isOwner(userId); }
      match /pointTransactions/{transactionId} { allow read, write: if isOwner(userId); }
      match /notifications/{notificationId} { allow read, write: if isOwner(userId); }
      match /referrals/{referralId} { allow read, write: if isOwner(userId); }
      
      // Sub-collections that also have a root collection counterpart.
      // Users can create and read their own requests.
      match /verificationRequests/{requestId} { allow get, list, create: if isOwner(userId); }
      match /withdrawalRequests/{requestId} { allow get, list, create: if isOwner(userId); }
      match /premium_subscriptions/{subscriptionId} { allow get, list, create: if isOwner(userId); }
    }

    // =================================================================
    // Admin-specific Root Collections
    // =================================================================
    // These root collections are used by the admin panel to manage requests.
    
    match /verificationRequests/{requestId} {
      // Admins can read, list, and update all requests.
      allow get, list, update: if isAdmin();
      // Users can create their own request here (mirrored from their subcollection).
      allow create: if isSignedIn();
    }

    match /withdrawalRequests/{requestId} {
      // Admins can read, list, and update all requests.
      allow get, list, update: if isAdmin();
      // Users can create their own request here.
      allow create: if isSignedIn();
    }

    match /premiumSubscriptions/{subscriptionId} {
      // Admins can read, list, and update all requests.
      allow get, list, update: if isAdmin();
      // Users can create their own request here.
      allow create: if isSignedIn();
    }

    // =================================================================
    // Public & Global Collections
    // =================================================================
    match /app_config/{configId} {
      allow get: if true; // Publicly readable
      allow write: if false; // Should be managed from console
    }

    match /ads/{adId} {
      allow get, list: if true; // Ads are public
      allow write: if false; // Managed from console
    }
  }
}
