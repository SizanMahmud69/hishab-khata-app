
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Root Collection: withdrawalRequests (For Console Management)
    match /withdrawalRequests/{requestId} {
      // Allow any authenticated user to create a withdrawal request
      allow create: if request.auth != null;
      // Allow a user to read their own request if it exists and matches their UID
      allow read: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      // Allow updates/deletes for admin management via console
      allow update, delete: if true; 
    }

    // User Data and Sub-collections
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Sub-collections under users follow path-based security
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // App Config (Publicly Readable)
    match /app_config/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Default Fallback (Authenticated only)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
