
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Root Collection: withdrawalRequests (For Console Management)
    match /withdrawalRequests/{requestId} {
      // Allow any authenticated user to create a request
      allow create: if request.auth != null;
      // Allow a user to read their own request from root OR if it doesn't exist yet
      allow read: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      // Allow updates (for console status changes)
      allow update, delete: if true; 
    }

    // User Data and Sub-collections
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Explicit rules for nested sub-collections to ensure path-based access
      match /withdrawalRequests/{requestId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /notifications/{id} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /transactions/{id} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /debtNotes/{id} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /referrals/{id} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; 
      }
      
      match /checkIns/{id} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /premium_subscriptions/{id} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /verificationRequests/{id} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // App Config (Publicly Readable)
    match /app_config/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Default Fallback (Authenticated only)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
