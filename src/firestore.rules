
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Basic user protection: Users can only read and write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Sub-collections under users follow path-based security
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // App Config (Publicly Readable for global settings)
    match /app_config/{docId} {
      allow read: if true;
      // Allow only the specific admin email to write global configs
      allow write: if request.auth != null && request.auth.token.email == 'hisabkhata.maintanance@gmail.com'; 
    }

    // Default Fallback (Authenticated only)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
