
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Basic user protection but allow root access for requested console management
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Explicitly allow access to withdrawalRequests root collection
    match /withdrawalRequests/{requestId} {
      allow read, write: if true;
    }

    // Publicly readable global configs
    match /app_config/{docId} {
      allow read: if true;
      allow write: if false; 
    }
    
    match /ads/{adId} {
      allow read: if true;
      allow write: if false;
    }

    // Fallback rule to prevent global blocks while developing
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
