
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      // A user is the owner if they are signed in and their UID matches the document's userId.
      return request.auth.uid == userId;
    }

    function isAdmin() {
      // An admin is a signed-in user with an 'isAdmin' flag set to true in their user document.
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // ------------------------------------------------------------------------
    // Collection Rules
    // ------------------------------------------------------------------------
    
    match /users/{userId} {
      // Admins can get/list any user. Users can only get their own document.
      allow get, list: if isOwner(userId) || isAdmin();
      // A signed-in user can create their own user document.
      allow create: if isSignedIn();
      // Admins can update any user. Users can only update their own.
      // A referred user can also update some fields on the referrer.
      allow update: if isOwner(userId) || isAdmin() || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['points', 'premiumStatus', 'premiumPlanId', 'premiumExpiryDate', 'lastAdWatchDate', 'lastSpinDate', 'spinsToday']));
      // Only admins can delete users.
      allow delete: if isAdmin();

      // Sub-collections are accessible to the owner or an admin.
      match /transactions/{transactionId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /debtNotes/{debtNoteId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /checkIns/{checkInId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /verificationRequests/{requestId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /withdrawalRequests/{requestId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /notifications/{notificationId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /referrals/{referralId} {
        // Referral records can be created by any signed-in user for another.
        // Reading is restricted to the owner of the referral list or an admin.
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isSignedIn() || isAdmin();
        allow update, delete: if false; // Disallow updates/deletes from client.
      }
      match /pointTransactions/{transactionId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /premium_subscriptions/{subscriptionId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
    
    // Global app configuration
    match /app_config/{configId} {
      allow get: if true; // Publicly readable
      // Admins can manage the entire config.
      allow list, write: if isAdmin();
      // Allow any signed-in user to create the config document if it doesn't exist.
      allow create: if isSignedIn();
    }
    
    // Root collection for verification requests for admin and uniqueness checks
    match /verificationRequests/{requestId} {
      // Any signed-in user can read for uniqueness checks. Admins can read too.
      allow get, list: if isSignedIn() || isAdmin();
      // Only users can create requests for themselves under certain conditions.
      allow create: if isSignedIn()
                      && request.resource.data.userId == request.auth.uid
                      && !exists(/databases/$(database)/documents/verificationRequests/$(request.resource.data.nidNumber))
                      && !exists(/databases/$(database)/documents/verificationRequests/$(request.resource.data.phone));
      // Only admins can update (approve/reject) or delete.
      allow update, delete: if isAdmin();
    }

    // Root collection for advertisements
    match /ads/{adId} {
      // Anyone can read the ads.
      allow get, list: if true;
      // Only admins can create, update, or delete ads.
      allow write: if isAdmin();
    }
  }
}
