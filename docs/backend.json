
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user in the system.",
      "properties": {
        "id": { "type": "string" },
        "points": { "type": "number" },
        "premiumStatus": { "type": "string", "enum": ["free", "premium"] }
      }
    },
    "WithdrawalRequest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "WithdrawalRequest",
      "type": "object",
      "description": "Represents a user's request to withdraw reward points. Managed via Firebase Console.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "points": { "type": "number" },
        "amountBdt": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "accountNumber": { "type": "string" },
        "requestedAt": { "type": "string", "format": "date-time" },
        "processedAt": { "type": "string", "format": "date-time" },
        "rejectionReason": { "type": "string" },
        "isRefunded": { "type": "boolean", "description": "Used by the app to track if points were returned after a manual rejection in console." }
      },
      "required": ["id", "userId", "status", "points", "amountBdt", "paymentMethod", "accountNumber", "requestedAt"]
    }
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "User" }
      },
      {
        "path": "/withdrawalRequests/{requestId}",
        "definition": {
          "entityName": "WithdrawalRequest",
          "description": "Root collection for all withdrawal requests. Admins manage this directly from Firebase Console by changing the 'status' field."
        }
      }
    ]
  }
}
